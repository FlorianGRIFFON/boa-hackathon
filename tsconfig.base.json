{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@boa/shared-types": ["./packages/shared-types/src/index.ts"],
      "@boa/shared-hooks": ["./packages/shared-hooks/src/index.ts"],
      "@boa/shared-ui": ["./packages/shared-ui/src/index.ts"]
    }
  }
}
